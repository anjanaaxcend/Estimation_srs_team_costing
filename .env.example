CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
GENERATED_DIR=backend/generated
NLP_TRAINING_DATA_PATH=backend/training/requirements_training_data.json
NLP_MODEL_ARTIFACT_PATH=backend/training/requirements_model.pkl
LOCAL_NLP_EXTRACTION_ENABLED=true
# OpenAI API Configuration
# To use OpenAI (Paid): 
# OPENAI_API_KEY=sk-xxxx
# OPENAI_SRS_MODEL=gpt-4o-mini

# To use Groq (Free):
# 1. Get a key at https://console.groq.com/
# 2. Use the following:
OPENAI_API_KEY=your_groq_api_key_here
OPENAI_API_BASE=https://api.groq.com/openai/v1
OPENAI_SRS_MODEL=llama-3.3-70b-versatile
OPENAI_SRS_FALLBACK_MODELS=meta-llama/llama-4-scout-17b-16e-instruct

# To use Gemini (Google AI Studio free tier):
# 1. Create one Gemini API key in Google AI Studio.
# 2. That single GEMINI_API_KEY is reused across Gemini models.
# 3. Your OpenAI/Groq key does NOT work for Gemini.
# 4. Prefer a current free-tier model such as Flash-Lite.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_SRS_MODEL=gemini-2.5-flash-lite
GEMINI_SRS_FALLBACK_MODELS=gemini-2.5-flash,gemini-flash-latest

# RAG & Features
OPENAI_REQUIREMENTS_ENABLED=true
OPENAI_REQUIREMENTS_MODEL=llama-3.3-70b-versatile
OPENAI_REQUIREMENTS_FALLBACK_MODELS=meta-llama/llama-4-scout-17b-16e-instruct
OPENAI_SRS_ENABLED=true
RAG_ENABLED=true
OPENAI_TIMEOUT_SECONDS=60
